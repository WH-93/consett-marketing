{
  "name": "consett-marketing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-preflight.js && next dev -p 3000",
    "build": "node scripts/build-preflight.js && next build",
    "start": "next start",
    "export": "next build",
    "test": "npm run test:unit",
    "test:unit": "npx tsx --test src/__tests__/components.test.ts src/__tests__/story-maps.test.ts src/__tests__/visual-style-contract.test.ts",
    "story-maps:write": "npx tsx scripts/write-story-map-json.ts",
    "deploy:cf": "npm run build && npx wrangler pages deploy out --project-name consett-marketing --branch main --commit-dirty=true"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  }
}
